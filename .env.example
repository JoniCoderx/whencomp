# ---------------------------------------------------------------------------
# When Comp — environment variables
# Copy this file to `.env` and fill in the values, then run `npm run db:push`.
#
# 100% free stack — NO paid APIs required. There are no OpenAI/Anthropic keys.
# ---------------------------------------------------------------------------

# Prisma database connection (PostgreSQL).
# Local dev or production: paste a Neon connection string (free tier at
# https://neon.tech). Use the DIRECT / non-pooled string so `prisma db push`
# and migrations work.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth ---------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Steam OAuth (placeholder — optional, not required to run the app) --------
STEAM_API_KEY=""
