// When Comp — Prisma schema
// Local dev = SQLite; production (Render/Neon) = PostgreSQL. Only `provider` differs.
// Dates are stored in UTC and displayed as Asia/Jerusalem in the UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  passwordHash   String
  displayName    String?
  avatarColor    String   @default("#f59e0b")
  role           String   @default("USER") // USER | ADMIN
  status         String   @default("ACTIVE") // ACTIVE | BANNED
  suspendedUntil DateTime?
  chatBanned     Boolean  @default(false)
  steamProfile   String?
  discordName    String?
  elo            Int      @default(1000)
  mvpCount       Int      @default(0)
  matchesPlayed  Int      @default(0)
  createdAt      DateTime @default(now())

  createdMatches Match[]        @relation("MatchCreator")
  participations Participant[]
  messages       Message[]
  notifications  Notification[]
  auditLogs      AuditLog[]     @relation("AuditActor")
  votesGiven     PlayerVote[]   @relation("VoteFrom")
  votesReceived  PlayerVote[]   @relation("VoteTo")
}

// Community up-votes for players (one per voter per target). Powers "top scores".
model PlayerVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  voterId  String
  voter    User   @relation("VoteFrom", fields: [voterId], references: [id], onDelete: Cascade)
  targetId String
  target   User   @relation("VoteTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([voterId, targetId])
}

model Match {
  id          String   @id @default(cuid())
  title       String
  game        String   @default("CS2")
  scheduledAt DateTime // UTC
  durationMin Int      @default(90)
  status      String   @default("UPCOMING") // UPCOMING | LIVE | COMPLETED | CANCELLED
  capacity    Int      @default(5)
  discordLink String?
  notes       String?
  isPrivate   Boolean  @default(false)
  inviteCode  String?  @unique
  createdAt   DateTime @default(now())

  creatorId String
  creator   User   @relation("MatchCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  participants Participant[]
  messages     Message[]
  ratings      Rating[]
}

model Participant {
  id         String   @id @default(cuid())
  status     String   @default("CONFIRMED") // CONFIRMED | WAITLIST | OUT
  outReason  String?
  outLate    Boolean  @default(false)
  attendance String? // ARRIVED | NOSHOW (set after the comp)
  joinedAt   DateTime @default(now())
  mvpVoteId  String?
  fpsRating  Int?

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model Message {
  id        String   @id @default(cuid())
  body      String
  kind      String   @default("USER") // USER | SYSTEM
  createdAt DateTime @default(now())

  matchId String
  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(cuid())
  kind      String // JOINED | FULL | SPOT_OPEN | STARTING | CHANGED | CANCELLED | CHAT
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId String?
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())

  adminId String
  admin   User   @relation("AuditActor", fields: [adminId], references: [id], onDelete: Cascade)
}

model Rating {
  id        String   @id @default(cuid())
  kind      String
  value     Int      @default(0)
  comment   String?
  createdAt DateTime @default(now())

  matchId    String
  match      Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  fromUserId String
  toUserId   String?
}
